# ── SQS Signal — Environment Configuration ────────────────────────────────
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# GitHub OAuth — OPTIONAL. Default OFF (unauthenticated mode).
# When disabled, the app runs without sign-in — all features available.
# Set GITHUB_AUTH_ENABLED=true and configure credentials to enable sign-in.
#
# Create an OAuth App at: https://github.com/settings/developers
# Homepage URL: https://sqs.chat
# Callback URL: https://sqs.chat/auth/github/callback
#
# sqs.chat (production) uses these — see README for setup.
GITHUB_AUTH_ENABLED=false
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=https://sqs.chat/auth/github/callback

# Whisper service URL (internal Docker network)
WHISPER_SERVICE_URL=http://whisper-service:8000

# File upload limits
MAX_FILE_SIZE_MB=50
DAILY_UPLOAD_LIMIT_MB=100
MAX_RECORDING_MINUTES=15

# Cookie security — set to True in production with HTTPS
# COOKIE_SECURE=True
